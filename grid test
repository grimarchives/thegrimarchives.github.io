<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pet Adoption Grid</title>

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
    }

    body {
        padding: 20px;
        background: #f5f5f5;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        text-align: center;
        padding-bottom: 15px;
    }

    .card img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }

    .buttons {
        margin-top: 12px;
        display: flex;
        justify-content: center;
        gap: 10px;
    }

    button {
        padding: 8px 16px;
        border: none;
        cursor: pointer;
        border-radius: 5px;
        font-weight: bold;
    }

    .info-btn {
        background: #3498db;
        color: white;
    }

    .adopt-btn {
        background: #2ecc71;
        color: white;
    }

    /* Modal */
    .modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        padding: 20px;
        border-radius: 10px;
        position: relative;
        max-width: 500px;
        width: 90%;
        text-align: center;
    }

    .modal-content img {
        width: 100%;
        border-radius: 8px;
    }

    .close {
        position: absolute;
        top: 10px;
        right: 15px;
        font-size: 24px;
        cursor: pointer;
        font-weight: bold;
    }

    @media (max-width: 900px) {
        .grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 500px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>
<body>

<div class="grid" id="petGrid"></div>

<!-- Modal -->
<div class="modal" id="infoModal">
    <div class="modal-content">
        <span class="close" id="closeModal">&times;</span>
        <img id="modalImage" src="" alt="">
        <h3 style="margin-top:15px;">Pet Information</h3>
        <p>This pet is looking for a loving home.</p>
    </div>
</div>

<script>
const grid = document.getElementById("petGrid");

// Create 16 cards
for (let i = 1; i <= 16; i++) {

    const imageUrl = `https://picsum.photos/300/250?random=${i}`;
    const largeImageUrl = `https://picsum.photos/600/450?random=${i}`;

    const card = document.createElement("div");
    card.className = "card";

    card.innerHTML = `
        <img src="${imageUrl}" alt="Pet ${i}">
        <div class="buttons">
            <button class="info-btn" onclick="openInfo('${largeImageUrl}')">
                INFO
            </button>
            <button class="adopt-btn" onclick="adoptPet(${i})">
                ADOPT
            </button>
        </div>
    `;

    grid.appendChild(card);
}

const modal = document.getElementById("infoModal");
const modalImage = document.getElementById("modalImage");

function openInfo(imageSrc) {
    modalImage.src = imageSrc;
    modal.style.display = "flex";
}

function closeInfo() {
    modal.style.display = "none";
}

document.getElementById("closeModal").addEventListener("click", closeInfo);

// Close when clicking outside modal content
modal.addEventListener("click", function(e) {
    if (e.target === modal) {
        closeInfo();
    }
});

function adoptPet(id) {
    alert(`You clicked ADOPT for Pet ${id}`);
}
</script>

</body>
</html>
